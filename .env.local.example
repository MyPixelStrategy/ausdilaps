# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ausdilaps.com.au
ADMIN_EMAIL=info@ausdilaps.com.au
SALES_NOTIFY_EMAIL=                 # optional CC for Tier-1 priority handoff
NEXT_PUBLIC_GA4_ID=G-81JV6BQ2R5

# ─── Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@ausdilaps.com.au

# ─── Spam (Cloudflare Turnstile) ─────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Storage (Cloudflare R2, S3-compatible) ──────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ausdilaps-reports
R2_ENDPOINT=                        # https://<account>.r2.cloudflarestorage.com

# ─── Salesforce (OAuth client-credentials) — dormant until enabled ───
SF_SYNC_ENABLED=false
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_VERSION=v60.0

# ─── Stripe (payment automation — deferred to Phase 7) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Lead engine ─────────────────────────────────────────────────────
LEAD_TEST_MODE=false                # true: insert to Supabase but route email to ADMIN_EMAIL, skip Salesforce
